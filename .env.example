# ---------------------------------------------------------------------------
# otel-genai-graph — local configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` (gitignored) and uncomment what you need.
# The loader, render_graph.py, and both capture scripts auto-load `.env`
# from the project root or any parent of the current working directory.
#
# Precedence: existing shell env vars always win; `.env` only fills blanks.
# That keeps CI / production overrides untouched.
# ---------------------------------------------------------------------------


# ───── Neo4j ────────────────────────────────────────────────────────────────
# Used by `python -m otel_genai_graph.load` and `tools/render_graph.py`.
# Default spin-up (matches the README quickstart):
#   docker run -d --name otel-neo4j -p 17474:7474 -p 17687:7687 \
#       -e NEO4J_AUTH=neo4j/testtest neo4j:5
#
#NEO4J_URI=bolt://localhost:17687
#NEO4J_USER=neo4j
#NEO4J_PASSWORD=testtest
#NEO4J_DATABASE=neo4j


# ───── Anthropic (capture_real_traces --provider anthropic) ─────────────────
#ANTHROPIC_API_KEY=sk-ant-...


# ───── OpenAI (capture_real_traces --provider openai) ───────────────────────
#OPENAI_API_KEY=sk-...

# OpenAI-compatible endpoints — set OPENAI_BASE_URL to redirect the SDK:
# Local Ollama:
#OPENAI_BASE_URL=http://localhost:11434/v1/
#OPENAI_API_KEY=ollama
# Groq:
#OPENAI_BASE_URL=https://api.groq.com/openai/v1


# ───── Google AI Studio (capture_real_traces --provider google) ─────────────
# Free tier, no credit card:  https://aistudio.google.com → API keys
#GEMINI_API_KEY=


# ───── Azure OpenAI (capture_real_traces --provider azure_openai{,_v1}) ─────
#AZURE_OPENAI_ENDPOINT=https://myres.openai.azure.com
#AZURE_OPENAI_API_KEY=
#AZURE_OPENAI_API_VERSION=2024-10-21


# ───── Azure AI Foundry unified inference endpoint ──────────────────────────
# (capture_real_traces --provider azure_inference)
#AZURE_AI_INFERENCE_ENDPOINT=https://proj.services.ai.azure.com/models
#AZURE_AI_INFERENCE_KEY=
#AZURE_AI_INFERENCE_API_VERSION=2024-10-21


# ───── Tuning — mainly for slow local models (Ollama) ──────────────────────
# Default timeout is 300 s; bump for bigger local models.
#OPENAI_TIMEOUT_SECONDS=600

# Cap each LLM response to N tokens. Without it, a 7B local model will
# cheerfully generate 4k tokens for a "hello" prompt. Set to 128–512 for
# fast iteration on Ollama.
#OPENAI_MAX_OUTPUT_TOKENS=256
